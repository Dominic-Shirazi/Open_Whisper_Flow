# Faster-Whisper Model Settings
# Options: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en, large-v1, large-v2, large-v3, distil-large-v2, distil-medium.en, distil-small.en, distil-large-v3
WHISPER_MODEL_SIZE=small.en
# Options: cpu, cuda, auto
WHISPER_DEVICE=cuda

# Windows Service Configuration
# Whether to run the API as a background service (false) or visible console window (true)
API_VISIBLE=false

# How often to restart the background service to clear VRAM (in hours)
RESTART_INTERVAL_HOURS=4

# Client Configuration
# Startup delay for the listener to wait for API
LISTEN_DELAY_SECONDS=10

# How many minutes of inactivity before the background listener gracefully restarts itself
LISTENER_RESTART_INTERVAL_MINS=30

# Local LLM API URL for Fast-Path processing
OLLAMA_API_URL=http://192.168.0.201:11434/api/generate
OLLAMA_MODEL=gpt-oss:20b
